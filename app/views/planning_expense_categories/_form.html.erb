<%= form_with(model: @category, id: @category.class.table_name, html: { autocomplete: 'off' }) do |f| %>
<%= f.hidden_field :planning_id %>

<div class="row mb-3">
    <div class="col-12 col-sm-12">
        <%= f.label :description, "Descrição" %>
        <%= f.text_field :description, class: 'form-control', placeholder: 'Alimentação' %>
        <div class="text-danger">
        <% if @category.errors.include?(:description) %>
            <% @category.errors.full_messages_for(:description).each do |error_message| %>
                <%= error_message %>.
            <% end %>
        <% end %>
        </div>
    </div>
</div>
<% end %>