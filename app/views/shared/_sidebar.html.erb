<div class="container-fluid">
  <button class="navbar-toggler ms-n2" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarCollapse" aria-controls="sidebarCollapse" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>

  <%= link_to '', class: 'navbar-brand py-lg-2 mb-lg-5 px-lg-6 me-0' do %>
    <%= image_tag 'imagotipo', class: 'img-fluid w-75 w-sm-100' %>
  <% end %>
  
  <div class="navbar-user d-lg-none">
    <div class="dropdown">
      <a href="#" id="sidebarAvatar" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
        <div class="avatar-parent-child">
            <div class="avatar rounded-circle bg-surface-secondary text-dark"><i class="bi bi-person"></i></div>
          <span class="avatar-child avatar-badge bg-success"></span>
        </div>
      </a>
      <div class="dropdown-menu dropdown-menu-end" aria-labelledby="sidebarAvatar">
        <%= link_to 'Configurações', '', class: 'dropdown-item' %>
        <%= link_to 'Logout', '', method: :get, class: 'dropdown-item' %>
      </div>
    </div>
  </div>
  
  <div class="collapse navbar-collapse" id="sidebarCollapse">
    <ul class="navbar-nav">
      <li class="nav-item">
        <%= link_to root_path, class: 'nav-link' do %>
          <i class="bi bi-clipboard-data"></i> Planejamento
        <% end %>
      </li>
    </ul>

    <div class="mt-auto d-none d-lg-block"></div>

    <hr class="d-none d-lg-block">

    <ul class="navbar-nav d-none d-lg-block">
      <li class="nav-item">
        <%= link_to settings_path, class: 'nav-link' do %>
          <i class="bi bi-gear"></i> Configurações
        <% end %>
      </li>
      <li class="nav-item">
        <%= link_to '', method: :get, class: 'nav-link' do %>
          <i class="bi bi-box-arrow-left"></i> Logout
        <% end %>
      </li>
    </ul>
  </div>
</div>
