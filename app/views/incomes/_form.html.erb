<%= form_with(model: @income, id: @income.class.table_name, html: { autocomplete: 'off' }) do |f| %>
<div class="row mb-3">
    <div class="col-12 col-sm-12">
        <%= f.label :description, "Descrição" %>
        <%= f.text_field :description, class: 'form-control', placeholder: 'SEFIN' %>
        <div class="text-danger">
        <% if @income.errors.include?(:description) %>
            <% @income.errors.full_messages_for(:description).each do |error_message| %>
                <%= error_message %>.
            <% end %>
        <% end %>
        </div>
    </div>
</div>
<div class="row mb-3">
    <div class="col-12 col-sm-12">
        <%= f.label :value, "Valor" %>
        <%= f.text_field :value, class: 'form-control real-currency', placeholder: 'R$ 3.500' %>
        <div class="text-danger">
        <% if @income.errors.include?(:value) %>
            <% @income.errors.full_messages_for(:value).each do |error_message| %>
                <%= error_message %>.
            <% end %>
        <% end %>
        </div>
    </div>
</div>
<div class="row mb-5">
    <div class="col-12 col-sm-12">
        <%= f.label :date, "Data" %>
        <%= f.text_field :date, class: 'form-control datepicker-dd-mm-yyyy', placeholder: Time.now.strftime("%d/%m/%Y") %>
        <div class="text-danger">
        <% if @income.errors.include?(:date) %>
            <% @income.errors.full_messages_for(:date).each do |error_message| %>
                <%= error_message %>.
            <% end %>
        <% end %>
        </div>
    </div>
</div>
<% end %>