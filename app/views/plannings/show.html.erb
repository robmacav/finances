<div class="row mb-5">
    <div class="col-12 col-sm-12">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-12 col-sm-12 d-sm-flex justify-content-between align-items-center">
                        <div class="mb-3 mb-sm-0">
                            <h3 class="card-title mb-0">Planejamento</h3>
                            <small><%= Date.strptime(@planning.month_year, '%m%Y').strftime("%m/%Y") %></small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <%= link_to plannings_path, class: 'btn btn-sm btn-neutral me-2 mb-2 mb-sm-0' do %>
                                <i class="bi bi-reply"></i> 
                                <span>Voltar</span>
                            <% end %>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 col-sm-12">
                        <ul class="nav nav-tabs" id="myTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="expenses-tab" data-bs-toggle="tab" data-bs-target="#expenses" type="button" role="tab" aria-controls="expenses" aria-selected="true">Despesas</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="incomes-tab" data-bs-toggle="tab" data-bs-target="#incomes" type="button" role="tab" aria-controls="profile" aria-selected="false">Receitas</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%= render 'stats', planning: @planning %>

<div class="tab-content" id="myTabContent">
  <div class="tab-pane fade show active" id="expenses" role="tabpanel" aria-labelledby="expenses-tab">
    <%= render 'expenses' %>
  </div>

  <div class="tab-pane fade show active" id="incomes" role="tabpanel" aria-labelledby="incomes-tab">
    <%= render 'incomes' %>
  </div>
</div>


